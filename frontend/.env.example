# Copy this file to .env.local and fill in the values.
# VITE_API_URL is the only required variable for a live backend connection.
# Leave it unset to run the frontend against built-in mock data.

VITE_API_URL=http://localhost:8000

# Optional — enables Google Maps Static API satellite images in building detail.
# Without this key the free ESRI World Imagery tile layer is used instead.
VITE_GOOGLE_MAPS_API_KEY=
